.fade-in-up {
  animation: fadeInUp 420ms ease-out;
}

.soft-press {
  transition: transform 180ms ease, opacity 180ms ease;
}

.soft-press:active {
  transform: scale(0.98);
  opacity: 0.9;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(12rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
