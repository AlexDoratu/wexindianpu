.panel {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-soft);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.chip {
  border-radius: 999rpx;
  background: var(--bg-soft);
  color: var(--text-secondary);
  font-size: 22rpx;
  padding: 12rpx 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  display: inline-flex;
}

.chip-active {
  background: #f1e3e0;
  color: var(--accent-deep);
}

.card-image {
  width: 100%;
  border-radius: var(--radius-md);
  background: #f0ece8;
}
