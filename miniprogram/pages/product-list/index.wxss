.chips-row { white-space: nowrap; margin-top: 16rpx; }
.chips-inner { display: flex; }
.item-image { height: 280rpx; }
.item-main { margin-top: 14rpx; }
.item-name { font-size: 30rpx; color: var(--text-primary); font-weight: 600; }
.item-intro { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; }
.item-tags { display: flex; flex-wrap: wrap; margin-top: 10rpx; }
.mini-tag { background: var(--bg-soft); color: var(--text-secondary); border-radius: 999rpx; padding: 6rpx 14rpx; font-size: 20rpx; margin-right: 8rpx; margin-bottom: 8rpx; }
.item-bottom { display: flex; justify-content: space-between; margin-top: 14rpx; align-items: center; }
.item-price { color: var(--accent-deep); font-weight: 600; }
.fav { color: var(--text-secondary); font-size: 24rpx; }
