<view class="safe-container fade-in-up">
  <swiper class="hero-swiper" autoplay interval="3800" circular indicator-dots indicator-color="#dccfc8" indicator-active-color="#8c6462">
    <block wx:for="{{banners}}" wx:key="id">
      <swiper-item>
        <view class="hero-card">
          <image class="hero-image" src="{{item.image}}" mode="aspectFill" />
          <view class="hero-overlay">
            <text class="hero-title">{{item.title}}</text>
          </view>
        </view>
      </swiper-item>
    </block>
  </swiper>

  <view class="panel">
    <view class="section-title">品类导览</view>
    <view class="section-subtitle">以舒适场景选择贴身单品</view>
    <view class="entry-row">
      <view class="entry soft-press" bindtap="goCategory">查看全部分类</view>
      <view class="entry soft-press" bindtap="goSeries">探索系列场景</view>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">系列精选</view>
    <block wx:for="{{seriesList}}" wx:key="id">
      <view class="series-item soft-press" bindtap="goSeries">
        <image class="series-image" src="{{item.image}}" mode="aspectFill"/>
        <view class="series-content">
          <view class="series-name">{{item.name}}</view>
          <view class="series-desc">{{item.description}}</view>
        </view>
      </view>
    </block>
  </view>

  <view class="panel">
    <view class="section-title">推荐商品</view>
    <view class="product-grid">
      <block wx:for="{{recommendList}}" wx:key="id">
        <view class="product-card soft-press" data-id="{{item.id}}" bindtap="openDetail">
          <image class="card-image product-image" src="{{item.image}}" mode="aspectFill"/>
          <view class="product-name">{{item.name}}</view>
          <view class="product-intro">{{item.intro}}</view>
          <view class="product-price">¥{{item.price}}</view>
        </view>
      </block>
    </view>
  </view>
</view>
