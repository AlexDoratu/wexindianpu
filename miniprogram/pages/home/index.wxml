<view class="container">
  <view class="card banner">
    <image class="banner-img" src="https://images.unsplash.com/photo-1485230895905-ec40ba36b9bc?auto=format&fit=crop&w=1000&q=80" mode="aspectFill" />
    <view class="brand-name">简衣女装</view>
    <view class="brand-desc">为小红书来的你，挑选简洁有质感的日常穿搭。</view>
  </view>

  <view class="card">
    <view class="section-title">主推款式</view>
    <view class="tag-list">
      <text class="tag">连衣裙</text>
      <text class="tag">上衣</text>
      <text class="tag">裤子</text>
      <text class="tag">套装</text>
    </view>
    <button class="primary-btn" bindtap="goProducts">查看全部商品</button>
  </view>

  <view class="card">
    <view class="section-title">联系客服</view>
    <view class="contact-text">如需推荐尺码或搭配建议，点击下方立即咨询。</view>
    <button class="primary-btn" bindtap="goLeadForm">立即咨询</button>
  </view>
</view>
