.banner-img {
  width: 100%;
  height: 280rpx;
  border-radius: 12rpx;
}
.brand-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-top: 20rpx;
}
.brand-desc {
  color: #666;
  margin-top: 8rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}
.tag-list {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}
.tag {
  background: #fdf1f4;
  color: #d85b7a;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}
.contact-text {
  margin-bottom: 20rpx;
  color: #666;
}
