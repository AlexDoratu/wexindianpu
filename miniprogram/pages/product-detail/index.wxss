.hero { height: 520rpx; }
.name-row { display: flex; justify-content: space-between; margin-top: 18rpx; }
.name { font-size: 34rpx; font-weight: 600; color: var(--text-primary); }
.intro { color: var(--text-secondary); margin-top: 8rpx; font-size: 24rpx; }
.fav { width: 72rpx; height: 72rpx; border-radius: 50%; background: var(--bg-soft); display:flex; align-items:center; justify-content:center; color: var(--accent-deep); font-size: 34rpx; }
.price { margin-top: 16rpx; color: var(--accent-deep); font-size: 32rpx; font-weight: 600; }
.fabric { margin-top: 10rpx; color: var(--text-secondary); font-size: 24rpx; }
.item-tags { margin-top: 12rpx; }
.mini-tag { background: var(--bg-soft); color: var(--text-secondary); border-radius: 999rpx; padding: 8rpx 14rpx; font-size: 20rpx; margin-right: 8rpx; }
.desc { color: var(--text-secondary); font-size: 26rpx; line-height: 1.8; white-space: pre-line; }
