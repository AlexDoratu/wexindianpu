.category-bar {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.category-list {
  display: inline-flex;
}

.category-item {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: #fff;
  margin-right: 12rpx;
  color: #6e665f;
}

.category-item.active {
  background: #b89b7a;
  color: #fff;
}

.product-card {
  display: flex;
}

.product-img {
  width: 190rpx;
  height: 190rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #4a433d;
}

.price {
  margin-top: 12rpx;
  color: #8f6f52;
  font-size: 32rpx;
  font-weight: bold;
}

.tag-wrap {
  margin-top: 14rpx;
}

.tag {
  display: inline-block;
  background: #efebe5;
  color: #6f675f;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
  font-size: 22rpx;
}

.loading {
  color: #888;
  text-align: center;
  padding: 20rpx 0;
}
