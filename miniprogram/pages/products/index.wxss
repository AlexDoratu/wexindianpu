.category-bar {
  white-space: nowrap;
  margin-bottom: 20rpx;
}
.category-list {
  display: inline-flex;
}
.category-item {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: #fff;
  margin-right: 12rpx;
  color: #666;
}
.category-item.active {
  background: #d85b7a;
  color: #fff;
}
.product-card {
  display: flex;
}
.product-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}
.product-info {
  flex: 1;
}
.product-name {
  font-size: 30rpx;
  font-weight: 600;
}
.product-meta {
  color: #888;
  margin-top: 8rpx;
}
.price {
  margin-top: 20rpx;
  color: #d85b7a;
  font-size: 32rpx;
  font-weight: bold;
}
.loading {
  color: #888;
  text-align: center;
  padding: 20rpx 0;
}
